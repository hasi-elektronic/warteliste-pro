# ── Cache-Regeln (Performance) ──────────────────────────────
# CanvasKit-WASM (~7 MB) aendert sich nur mit der Flutter-SDK-Version,
# nicht pro Deploy → sehr lange cachen. Spart bei jedem Wiederbesuch
# den kompletten Re-Download.
/canvaskit/*
  Cache-Control: public, max-age=31536000, immutable

# Assets (Vordrucke, Fonts, AssetManifest) — lange cachen.
/assets/*
  Cache-Control: public, max-age=2592000

/icons/*
  Cache-Control: public, max-age=2592000

# Alle WASM-Dateien lange cachen.
/*.wasm
  Cache-Control: public, max-age=31536000, immutable

# main.dart.js + flutter_bootstrap.js aendern sich pro Deploy und sind
# NICHT hash-benannt → nur mit ETag revalidieren (schnelles 304 wenn
# unveraendert, voller Download nur nach neuem Deploy). So vermeiden wir
# veraltete JS-Bundles UND unnoetige 6-MB-Downloads bei jedem Besuch.
/main.dart.js
  Cache-Control: public, max-age=0, must-revalidate

/flutter_bootstrap.js
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

# ── Sicherheits-Header (fuer alle Pfade) ────────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://www.gstatic.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://www.gstatic.com data:; img-src 'self' data: blob: https: ; media-src 'self' data: blob:; connect-src 'self' blob: https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.gstatic.com https://fonts.googleapis.com https://warteliste-pro-r2.hguencavdi.workers.dev https://firestore.googleapis.com https://firebaseinstallations.googleapis.com https://securetoken.googleapis.com https://identitytoolkit.googleapis.com https://firebase.googleapis.com https://www.googleapis.com wss://*.firebaseio.com; worker-src 'self' blob:; frame-src 'self' https://warteliste-pro.firebaseapp.com; object-src 'none'; base-uri 'self'; form-action 'self'
