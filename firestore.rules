rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================= Helpers =================
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Deterministische Invite-Doc-ID: {praxisId}__{normalizedEmail}
    function inviteIdFor(praxisId, email) {
      return praxisId + '__' + email.lower();
    }

    function hasMatchingInvite(praxisId, email) {
      return exists(
        /databases/$(database)/documents/invites/$(inviteIdFor(praxisId, email))
      );
    }

    function isPraxisOwnedBy(praxisId, uid) {
      return exists(/databases/$(database)/documents/praxen/$(praxisId))
        && get(/databases/$(database)/documents/praxen/$(praxisId))
             .data.get('createdBy', '') == uid;
    }

    // Admin der Praxis: User-Doc hat role=admin UND praxisId ist in
    // praxisIds (oder primary praxisId). Erlaubt mehrere Administratoren
    // pro Praxis ohne dass jeder der "Owner" sein muss.
    function isPraxisAdmin(praxisId) {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return signedIn()
        && exists(userRef)
        && get(userRef).data.get('role', '') == 'admin'
        && (
          get(userRef).data.get('praxisId', '') == praxisId
          || praxisId in get(userRef).data.get('praxisIds', [])
        );
    }

    // Mitgliedschaft: users/{uid}.praxisIds ist Quelle der Wahrheit, weil
    // Schreibzugriff auf dieses Feld via Regeln streng gated ist
    // (Hinzufuegen erfordert Ownership oder Invite).
    function isPraxisMember(praxisId) {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return signedIn()
        && exists(userRef)
        && (
          get(userRef).data.get('praxisId', '') == praxisId
          || praxisId in get(userRef).data.get('praxisIds', [])
        );
    }

    // Admin-Zugriff ueber das Praxis-Dokument selbst (admins-Array bzw.
    // Ersteller). Unabhaengig von users/{uid}.praxisIds — dadurch kann ein
    // Admin den Zugriff auf seinen eigenen Standort NICHT verlieren (z.B.
    // durch versehentliches "Standort entfernen").
    function isPraxisAdminDoc(praxisId) {
      let praxisRef = /databases/$(database)/documents/praxen/$(praxisId);
      return signedIn()
        && exists(praxisRef)
        && (
          request.auth.uid in get(praxisRef).data.get('admins', [])
          || get(praxisRef).data.get('createdBy', '') == request.auth.uid
        );
    }

    // Zugriff auf eine Praxis + ihre Subcollections: Mitglied ODER Admin.
    function canAccessPraxis(praxisId) {
      return isPraxisMember(praxisId) || isPraxisAdminDoc(praxisId);
    }

    // Ist der Aufrufer Admin MINDESTENS eines Standorts aus `list`?
    // Kurzschluss (||) haelt die get()-Kosten klein; max. 3 Eintraege wegen
    // des Firestore-Limits von 10 get()/exists() pro Request.
    function actorAdminsAnyOf(list) {
      let n = list.size();
      return (n >= 1 && isPraxisAdminDoc(list[0]))
        || (n >= 2 && isPraxisAdminDoc(list[1]))
        || (n >= 3 && isPraxisAdminDoc(list[2]));
    }

    // Ist der Aufrufer Admin JEDES Standorts aus `list`? (leere Liste = true)
    function actorAdminsAllOf(list) {
      let n = list.size();
      return n <= 3
        && (n < 1 || isPraxisAdminDoc(list[0]))
        && (n < 2 || isPraxisAdminDoc(list[1]))
        && (n < 3 || isPraxisAdminDoc(list[2]));
    }

    // Prueft, ob ein einzelner praxisId-Eintrag fuer den User zulaessig ist.
    // Entweder: schon vorher im Dokument (=> war legitim), ODER
    // der User hat die Praxis erstellt, ODER er hat ein passendes Invite.
    function praxisEntryAllowed(pid, beforeList, uid, email) {
      return pid in beforeList
        || isPraxisOwnedBy(pid, uid)
        || hasMatchingInvite(pid, email);
    }

    // Jede praxisId in der afterList muss zulaessig sein.
    // Enumeration bis max. 10 Eintraege (harte Grenze pro Dokument).
    function eachPraxisIdAllowed(afterList, beforeList, uid, email) {
      let n = afterList.size();
      return n <= 10
        && (n < 1 || praxisEntryAllowed(afterList[0], beforeList, uid, email))
        && (n < 2 || praxisEntryAllowed(afterList[1], beforeList, uid, email))
        && (n < 3 || praxisEntryAllowed(afterList[2], beforeList, uid, email))
        && (n < 4 || praxisEntryAllowed(afterList[3], beforeList, uid, email))
        && (n < 5 || praxisEntryAllowed(afterList[4], beforeList, uid, email))
        && (n < 6 || praxisEntryAllowed(afterList[5], beforeList, uid, email))
        && (n < 7 || praxisEntryAllowed(afterList[6], beforeList, uid, email))
        && (n < 8 || praxisEntryAllowed(afterList[7], beforeList, uid, email))
        && (n < 9 || praxisEntryAllowed(afterList[8], beforeList, uid, email))
        && (n < 10 || praxisEntryAllowed(afterList[9], beforeList, uid, email));
    }

    // ================= /users/{userId} =================
    match /users/{userId} {
      // Read: sich selbst ODER — fuer die Mitarbeiter-Verwaltung — ein Admin,
      // der mindestens einen Standort dieses Nutzers administriert.
      allow read: if isSelf(userId)
        || (
          resource != null
          && resource.data != null
          && actorAdminsAnyOf(resource.data.get('praxisIds', []))
        );

      allow create: if isSelf(userId)
        && request.resource.data.get('email', '') == request.auth.token.email
        && eachPraxisIdAllowed(
             request.resource.data.get('praxisIds', []),
             [],
             request.auth.uid,
             request.auth.token.email
           )
        && (
          !('praxisId' in request.resource.data)
          || request.resource.data.praxisId == ''
          || praxisEntryAllowed(
               request.resource.data.praxisId,
               request.resource.data.get('praxisIds', []),
               request.auth.uid,
               request.auth.token.email
             )
        );

      // UPDATE kritisch: role darf nicht veraendert werden (nur via Admin-
      // Prozess, den wir nicht mehr client-seitig erlauben). email darf
      // auch nicht veraendert werden. praxisIds/praxisId jeder Eintrag
      // muss autorisiert sein.
      allow update: if (
          isSelf(userId)
          && request.resource.data.get('email', '') == resource.data.get('email', '')
          && request.resource.data.get('role', 'admin') == resource.data.get('role', 'admin')
          && eachPraxisIdAllowed(
               request.resource.data.get('praxisIds', []),
               resource.data.get('praxisIds', []),
               request.auth.uid,
               request.auth.token.email
             )
          && (
            !('praxisId' in request.resource.data)
            || request.resource.data.praxisId == ''
            || praxisEntryAllowed(
                 request.resource.data.praxisId,
                 resource.data.get('praxisIds', []),
                 request.auth.uid,
                 request.auth.token.email
               )
            || request.resource.data.praxisId in request.resource.data.get('praxisIds', [])
          )
        )
        // ---- Mitarbeiter-Verwaltung durch einen Standort-Admin ----
        // Ein Admin darf den Standort-Zugriff EINES ANDEREN Nutzers pflegen.
        // Streng begrenzt:
        //  * nur die Felder praxisIds/praxisId duerfen sich aendern
        //    (=> role/email unveraenderbar, keine Rechte-Eskalation),
        //  * jeder hinzugefuegte UND entfernte Standort muss vom Aufrufer
        //    administriert werden (=> keine fremden Mandanten),
        //  * praxisId (aktiver Standort) muss in praxisIds enthalten bleiben.
        || (
          signedIn()
          && request.auth.uid != userId
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['praxisIds', 'praxisId'])
          && actorAdminsAllOf(
               request.resource.data.get('praxisIds', [])
                 .removeAll(resource.data.get('praxisIds', []))
             )
          && actorAdminsAllOf(
               resource.data.get('praxisIds', [])
                 .removeAll(request.resource.data.get('praxisIds', []))
             )
          && (
            request.resource.data.get('praxisId', '') == ''
            || request.resource.data.get('praxisId', '')
                 in request.resource.data.get('praxisIds', [])
          )
        );

      // Self-delete erlaubt (z.B. Account-Loeschung)
      allow delete: if isSelf(userId);
    }

    // ================= /invites/{inviteId} =================
    match /invites/{inviteId} {
      // Read: Empfaenger (per email) ODER Owner/Admin der Praxis
      allow read: if signedIn()
        && (
          resource.data.get('email', '') == request.auth.token.email
          || isPraxisOwnedBy(resource.data.get('praxisId', ''), request.auth.uid)
          || isPraxisAdmin(resource.data.get('praxisId', ''))
        );

      // Create: Owner ODER Admin der Ziel-Praxis; deterministische ID
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['email', 'praxisId'])
        && (
          isPraxisOwnedBy(request.resource.data.praxisId, request.auth.uid)
          || isPraxisAdmin(request.resource.data.praxisId)
        )
        && inviteId == inviteIdFor(
             request.resource.data.praxisId,
             request.resource.data.email
           );

      allow update: if false;

      // Delete: Empfaenger (nach Einloesung) ODER Owner/Admin
      allow delete: if signedIn()
        && (
          resource.data.get('email', '') == request.auth.token.email
          || isPraxisOwnedBy(resource.data.get('praxisId', ''), request.auth.uid)
          || isPraxisAdmin(resource.data.get('praxisId', ''))
        );
    }

    // ================= /praxen/{praxisId} =================
    match /praxen/{praxisId} {
      // Read: Mitglieder ODER Legacy-Selbst-Claim (praxis ohne createdBy,
      // Email gleicht auth.token.email).
      // Read: Mitglieder, Admins (admins-Array/Ersteller — ohne get(), da wir
      // genau dieses Dokument lesen; ermoeglicht auch die Query
      // `praxen where admins array-contains uid`), ODER Legacy-Selbst-Claim.
      allow read: if isPraxisMember(praxisId)
        || (signedIn() && request.auth.uid in resource.data.get('admins', []))
        || (signedIn() && resource.data.get('createdBy', '') == request.auth.uid)
        || (
          signedIn()
          && resource.data.get('createdBy', '') == ''
          && resource.data.get('email', '') == request.auth.token.email
        );

      // Create: nur mit createdBy == auth.uid
      allow create: if signedIn()
        && request.resource.data.get('createdBy', '') == request.auth.uid;

      // Update:
      //  (1) Admin oder Owner der Praxis; createdBy bleibt unveraendert.
      //      Normale Mitarbeiter duerfen Stammdaten (Name, Email, Adresse)
      //      NICHT aendern — nur Subcollections (Patienten etc.). ODER
      //  (2) Selbst-Claim: legacy Praxis ohne createdBy, Email matcht,
      //      nur das Feld createdBy darf sich aendern.
      allow update: if (
          (
            isPraxisAdmin(praxisId)
            || isPraxisOwnedBy(praxisId, request.auth.uid)
            || isPraxisAdminDoc(praxisId)
          )
          && request.resource.data.get('createdBy', '') ==
             resource.data.get('createdBy', '')
        )
        || (
          signedIn()
          && resource.data.get('createdBy', '') == ''
          && resource.data.get('email', '') == request.auth.token.email
          && request.resource.data.get('createdBy', '') == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['createdBy'])
        );

      allow delete: if isPraxisOwnedBy(praxisId, request.auth.uid);

      // ------- Subcollections (Mitglieder ODER Admins des Standorts) -------
      match /patienten/{patientId} {
        allow read, write: if canAccessPraxis(praxisId);

        match /notizen/{noteId} {
          allow read, write: if canAccessPraxis(praxisId);
        }
        match /dokumente/{dokumentId} {
          allow read, write: if canAccessPraxis(praxisId);
        }
      }

      // Mitarbeiter-Index eines Standorts: { email, role, joinedAt }.
      //
      // WICHTIG — warum dieser Index existiert: Bei einer Collection-Query
      // (`list`) ist `resource` in den Rules NULL. Eine Regel wie
      // "users lesen, wenn ich Admin eines seiner Standorte bin" kann darum
      // NICHT fuer `users`-Queries ausgewertet werden (Firestore lehnt ab).
      // Hier haengt die Regel nur am Pfad (praxisId) — deshalb ist die Query
      // erlaubt. Quelle der Wahrheit fuer den Zugriff bleibt
      // users/{uid}.praxisIds; dies ist nur der Index fuer die Anzeige.
      match /mitarbeiter/{mitarbeiterUid} {
        allow read: if canAccessPraxis(praxisId);
        // Eigenen Eintrag darf jedes Mitglied pflegen, alle anderen nur Admins.
        allow write: if canAccessPraxis(praxisId)
          && (
            mitarbeiterUid == request.auth.uid
            || isPraxisAdminDoc(praxisId)
          );
      }

      match /therapeuten/{therapeutId} {
        allow read, write: if canAccessPraxis(praxisId);
      }

      match /aerzte/{arztId} {
        allow read, write: if canAccessPraxis(praxisId);
      }

      match /termine/{terminId} {
        allow read, write: if canAccessPraxis(praxisId);
      }

      match /tokens/{tokenId} {
        allow read, write: if canAccessPraxis(praxisId);
      }

      // Berichte: praxen-weit, alle Mitarbeiter sehen sie
      match /berichte/{berichtId} {
        allow read, write: if canAccessPraxis(praxisId);
      }
    }
  }
}
